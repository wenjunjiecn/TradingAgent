{
  "name": "trading-agent",
  "productName": "Trading Agent",
  "version": "1.0.0",
  "description": "Desktop app for Mastra Trading Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tradingagent.app",
    "productName": "Trading Agent",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "directories": {
      "output": "dist"
    }
  }
}
