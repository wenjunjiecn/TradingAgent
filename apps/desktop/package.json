{
  "name": "@trading-agent/desktop",
  "productName": "Trading Agent",
  "version": "1.0.0",
  "description": "React + Vite + Electron desktop app for Mastra Trading Agent",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "npm run build:electron && electron .",
    "start": "npm run dev",
    "dev:renderer": "vite --host 127.0.0.1 --port 3000",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit -p tsconfig.vite.json && tsc --noEmit -p tsconfig.electron.json",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview --host 127.0.0.1 --port 3000",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@autoform/core": "^3.0.0",
    "@autoform/react": "^4.0.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/view": "^6.43.1",
    "@dagrejs/dagre": "^1.1.8",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^3.10.0",
    "@lukeed/uuid": "^2.0.1",
    "@mastra/ai-sdk": "^1.6.1",
    "@mastra/client-js": "^1.29.0",
    "@mastra/core": "^1.50.1",
    "@mastra/playground-ui": "*",
    "@mastra/react": "^1.2.1",
    "@mastra/schema-compat": "^1.3.2",
    "@mcp-ui/client": "^7.1.0",
    "@posthog/react": "^1.10.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@trading-agent/shared": "*",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.10.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.522.0",
    "nanoid": "^5.1.11",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.383.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^4.7.3",
    "react-router": "^7.13.1",
    "react-syntax-highlighter": "^15.6.6",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.4",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tree-kill": "^1.2.2",
    "use-debounce": "^10.1.0",
    "zod": "^3.25.0",
    "zod-v4": "npm:zod@^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@mastra/memory": "^1.22.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "msw": "^2.6.0",
    "nodemon": "^3.1.14",
    "react-grab": "^0.1.37",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.tradingagent.app",
    "productName": "Trading Agent",
    "electronVersion": "31.0.0",
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "extraResources": [
      {
        "from": "../agent-server/.mastra/output",
        "to": "agent-server",
        "filter": [
          "**/*",
          "!preflight-local-paths.json",
          "!**/*.db",
          "!**/*.db-shm",
          "!**/*.db-wal",
          "!**/*.duckdb",
          "!**/*.duckdb.wal"
        ]
      }
    ],
    "directories": {
      "output": "dist-app"
    }
  }
}
