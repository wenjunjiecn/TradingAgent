{
  "name": "trading-agent",
  "productName": "Trading Agent",
  "version": "1.0.0",
  "description": "Desktop app for Mastra Trading Agent",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "prestart": "npm run build",
    "start": "electron .",
    "dev": "concurrently --kill-others \"npm run build:watch\" \"nodemon --watch dist --ext js --delay 500ms --exec 'electron .'\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "@trading-agent/shared": "*",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.14",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.tradingagent.app",
    "productName": "Trading Agent",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "directories": {
      "output": "dist-app"
    }
  }
}
