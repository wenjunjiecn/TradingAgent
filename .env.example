# DeepSeek API（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Finnhub API（可选，用于新闻情绪工具）
# 免费注册: https://finnhub.io/register
# FINNHUB_API_KEY=your-finnhub-api-key-here

# Mastra Platform（可选，用于云端观测）
# MASTRA_PLATFORM_ACCESS_TOKEN=your-token

# 数据库路径（可选，默认 ~/.trading-agent/mastra.db）
# MASTRA_DB_URL=file:~/.trading-agent/mastra.db

# Desktop 与 Agent Server 之间的认证 Token（可选，生产打包时使用）
# TRADING_AGENT_DESKTOP_TOKEN=your-secure-token
